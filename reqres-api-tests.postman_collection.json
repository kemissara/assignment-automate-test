{
  "info": {
    "name": "JSONPlaceholder API Automation",
    "_postman_id": "a1b2c3d4-e2e2-4f4f-9a9a-automation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET Posts",
      "request": {
        "method": "GET",
        "header": [],
        "url": "https://jsonplaceholder.typicode.com/posts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is array', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "",
              "pm.test('Array is not empty', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.length).to.be.greaterThan(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Create Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"foo\",\n  \"body\": \"bar\",\n  \"userId\": 1\n}"
        },
        "url": "https://jsonplaceholder.typicode.com/posts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has id', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.exist;",
              "});",
              "",
              "pm.test('Response contains sent data', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.title).to.eql('foo');",
              "    pm.expect(jsonData.body).to.eql('bar');",
              "    pm.expect(jsonData.userId).to.eql(1);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Negative Test - Invalid Payload",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": "https://jsonplaceholder.typicode.com/posts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Request still returns response (mock API behavior)', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response contains id', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.exist;",
              "});"
            ]
          }
        }
      ]
    }
  ]
}